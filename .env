# Docker Compose host binding. Keep 127.0.0.1 for local-only use; use 0.0.0.0
# only behind a properly configured HTTPS reverse proxy/tunnel.
DROP_POINT_HOST_BIND=127.0.0.1
DROP_POINT_PORT=8080

# DropPoint service configuration.
DROP_POINT_LISTEN_ADDR=:8080
DROP_POINT_BASE_URL=http://localhost:8080
DROP_POINT_DATA_DIR=/var/lib/drop-point
DROP_POINT_DEFAULT_TTL_SECONDS=600
DROP_POINT_MAX_TTL_SECONDS=900
DROP_POINT_DEFAULT_MAX_BYTES=52428800
DROP_POINT_MAX_BYTES=52428800
DROP_POINT_DEFAULT_MAX_ACTIVE_DROP_POINTS=3
DROP_POINT_READ_TIMEOUT_SECONDS=600
DROP_POINT_WRITE_TIMEOUT_SECONDS=600
DROP_POINT_CLEANUP_INTERVAL_SECONDS=60
DROP_POINT_TERMINAL_RETENTION_SECONDS=2592000

# Receiver API tokens as JSON. The service starts with no receiver tokens.
# Generate token material with:
#   docker compose run --rm drop-point token generate
# Then replace [] with an entry using the printed secret_hash, for example:
#   [{"id":"desktop-main","secret_hash":"sha256:<lowercase-hex-sha256>","enabled":true,"max_active_drop_points":3}]
# Do not store the plaintext API token here.
DROP_POINT_API_TOKENS_JSON=[]
