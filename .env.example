# Docker Compose host binding. Keep 127.0.0.1 for local-only use; use 0.0.0.0
# only behind a properly configured HTTPS reverse proxy/tunnel.
DROPPOINT_HOST_BIND=127.0.0.1
DROPPOINT_PORT=8080

# DropPoint service configuration.
DROPPOINT_LISTEN_ADDR=:8080
DROPPOINT_BASE_URL=http://localhost:8080
DROPPOINT_DATA_DIR=/var/lib/droppoint
DROPPOINT_DEFAULT_TTL_SECONDS=600
DROPPOINT_MAX_TTL_SECONDS=900
DROPPOINT_DEFAULT_MAX_BYTES=52428800
DROPPOINT_MAX_BYTES=52428800
DROPPOINT_DEFAULT_MAX_ACTIVE_DROP_POINTS=3
DROPPOINT_READ_TIMEOUT_SECONDS=600
DROPPOINT_WRITE_TIMEOUT_SECONDS=600
DROPPOINT_CLEANUP_INTERVAL_SECONDS=60
DROPPOINT_TERMINAL_RETENTION_SECONDS=2592000

# Receiver API tokens as JSON. The service starts with no receiver tokens.
# Generate token material with:
#   docker compose run --rm droppoint token generate
# Then replace [] with an entry using the printed secret_hash, for example:
#   [{"id":"desktop-main","secret_hash":"sha256:<lowercase-hex-sha256>","enabled":true,"max_active_drop_points":3}]
# Do not store the plaintext API token here.
DROPPOINT_API_TOKENS_JSON=[]
